{
  "name": "us-exe-mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.106.1",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.0",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-device": "~8.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eas-cli": "^19.0.8",
    "typescript": "~5.9.2"
  },
  "scripts": {
    "start": "expo start",
    "start:dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:dev:android": "eas build --profile development --platform android",
    "eas:dev:ios": "eas build --profile development --platform ios",
    "eas:preview:android": "eas build --profile preview --platform android",
    "eas:preview:android:clean": "eas build --profile preview --platform android --clear-cache",
    "android:uninstall": "adb uninstall com.anonymous.usexemobile || adb shell pm uninstall --user 0 com.anonymous.usexemobile",
    "eas:prod:android": "eas build --profile production --platform android"
  },
  "private": true
}
