{
  "expo": {
    "name": "Us.exe Mobile",
    "slug": "us-exe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "usexe",
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#ec4899",
          "defaultChannel": "partner-sparks",
          "sounds": [
            "./assets/sounds/buzz.wav",
            "./assets/sounds/love_you.wav",
            "./assets/sounds/need_hugs.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ]
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Us.exe to save doodles to your photo library.",
          "savePhotosPermission": "Allow Us.exe to save doodles to your photo library."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.usexemobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#3D2E52",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "color": "#ec4899"
    },
    "extra": {
      "supabaseUrl": "https://pmthoctmhjilhhduvkpt.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBtdGhvY3RtaGppbGhoZHV2a3B0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzg5MzAyNTgsImV4cCI6MjA5NDUwNjI1OH0.FHW5-Cwwx5oZ-V2knPLB8LyR3dLw81mqzmrkvr9MTdQ",
      "expoCredentialsUrl": "https://expo.dev/accounts/dptspartan/projects/us-exe-mobile/credentials",
      "appEnv": "production",
      "eas": {
        "projectId": "ef0ca527-53b7-4e6a-bde9-afde99890794"
      }
    }
  }
}
