{
  "expo": {
    "name": "Us.exe Mobile",
    "slug": "us-exe-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "usexe",
    "plugins": [
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#ec4899",
          "defaultChannel": "partner-sparks",
          "sounds": [
            "./assets/sounds/buzz.wav",
            "./assets/sounds/love_you.wav",
            "./assets/sounds/need_hugs.wav"
          ]
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "buildArchs": [
              "armeabi-v7a",
              "arm64-v8a"
            ]
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Us.exe to save doodles to your photo library.",
          "savePhotosPermission": "Allow Us.exe to save doodles to your photo library."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.anonymous.usexemobile",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#3D2E52",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "notification": {
      "color": "#ec4899"
    },
    "extra": {}
  }
}
